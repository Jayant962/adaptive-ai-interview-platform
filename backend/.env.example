# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-64-char-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Groq API (free at console.groq.com) ──────────────────────
GROQ_API_KEY=gsk_your_key_here

# ── CORS — comma-separated list of allowed frontend origins ──
# Local dev:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# Production (add your Vercel/Netlify/Render URL):
# ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ── Email (optional — for password reset) ────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com

# ── Database ──────────────────────────────────────────────────
# SQLite for dev/free hosting:
DATABASE_URL=sqlite:///./interview_platform.db
# PostgreSQL for production (Render free tier):
# DATABASE_URL=postgresql://user:pass@host/dbname
